# Required: Anthropic API key for Claude LLM calls
ANTHROPIC_API_KEY=

# Optional: Google service account credentials as JSON string
# (alternative to placing credentials.json in project root)
# GOOGLE_SERVICE_ACCOUNT_JSON={
  "type": "",
  "project_id": "",
  "private_key_id": "",
  "private_key": "",
  "client_email": "",
  "client_id": "",
  "auth_uri": "",
  "token_uri": "",
  "auth_provider_x509_cert_url": "",
  "client_x509_cert_url": "",
  "universe_domain": "googleapis.com"
}

# Optional: Override the default Google Drive folder ID
# GDRIVE_FOLDER_ID=
