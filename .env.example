# Anthropic API key (required for LLM-powered pipeline steps)
ANTHROPIC_API_KEY=


# Google Drive authentication (pick ONE option):
#
# Option 1: Place the downloaded service account JSON file as credentials.json
#            in the project root. No env var needed.
#
# Option 2: Paste the entire JSON content as a single-line string here.
#            Useful for CI/CD or environments where you can't place a file.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# Optional: Override the default Google Drive folder ID
# GDRIVE_FOLDER_ID=